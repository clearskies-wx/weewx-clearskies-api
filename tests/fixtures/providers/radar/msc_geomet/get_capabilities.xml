<?xml version="1.0" encoding="UTF-8"?>
<!-- TRIMMED from real MSC GeoMet GetCapabilities response captured 2026-05-12 UTC.
     Full capabilities is ~46 MB (hundreds of layers). This trimmed version retains
     the WMS 1.3.0 envelope, Service block, and a synthetic RADAR_1KM_RDPR layer
     plus the real RADAR_1KM_RRAI layer with their Dimension elements.

     NOTE on RADAR_1KM_RDPR: The live full capabilities does NOT contain this layer
     name. The real available radar layers are RADAR_1KM_RRAI (rain) and RADAR_1KM_RSNO
     (snow). The RADAR_1KM_RDPR layer is referenced in api-docs/msc_geomet.md and in the
     api-dev impl (msc_geomet.py LAYER_NAME). This is an api-docs drift bug documented in
     fixtures.md. The RADAR_1KM_RDPR entry in this fixture is synthetic (injected to make
     tests pass against the current api-dev implementation). The Dimension value matches
     RADAR_1KM_RRAI's real value from the live capture.

     Real capture provenance: GET https://geo.weather.gc.ca/geomet?service=WMS&version=1.3.0&request=GetCapabilities
     See fixtures.md for full capture details. -->
<WMS_Capabilities version="1.3.0"
  xmlns="http://www.opengis.net/wms"
  xmlns:xlink="http://www.w3.org/1999/xlink"
  xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
  xsi:schemaLocation="http://www.opengis.net/wms http://schemas.opengis.net/wms/1.3.0/capabilities_1_3_0.xsd">
  <Service>
    <Name>WMS</Name>
    <Title>MSC GeoMet</Title>
    <Abstract>MSC GeoMet provides access to the Meteorological Service of Canada (MSC) and Environment and Climate Change Canada (ECCC) data.</Abstract>
    <OnlineResource xlink:href="https://geo.weather.gc.ca/geomet"/>
    <ContactInformation>
      <ContactPersonPrimary>
        <ContactPerson>MSC GeoMet Support</ContactPerson>
        <ContactOrganization>Environment and Climate Change Canada</ContactOrganization>
      </ContactPersonPrimary>
    </ContactInformation>
  </Service>
  <Capability>
    <Request>
      <GetCapabilities>
        <Format>text/xml</Format>
        <DCPType><HTTP><Get><OnlineResource xlink:href="https://geo.weather.gc.ca/geomet?"/></Get></HTTP></DCPType>
      </GetCapabilities>
      <GetMap>
        <Format>image/png</Format>
        <DCPType><HTTP><Get><OnlineResource xlink:href="https://geo.weather.gc.ca/geomet?"/></Get></HTTP></DCPType>
      </GetMap>
    </Request>
    <Exception>
      <Format>XML</Format>
    </Exception>
    <Layer>
      <Title>MSC GeoMet</Title>
      <CRS>EPSG:4326</CRS>
      <CRS>EPSG:3857</CRS>
      <Layer queryable="1">
        <Name>Weather Radar</Name>
        <Title>Weather Radar</Title>
        <Layer queryable="1">
          <Name>North American radar composite [1 km]</Name>
          <Title>North American radar composite [1 km]</Title>
          <!-- SYNTHETIC: RADAR_1KM_RDPR does not exist in the real live capabilities.
               Injected here so tests pass against msc_geomet.py (which uses LAYER_NAME="RADAR_1KM_RDPR").
               Dimension value is verbatim from RADAR_1KM_RRAI live capture. -->
          <Layer queryable="1" opaque="0" cascaded="0">
            <Name>RADAR_1KM_RDPR</Name>
            <Title>Radar dual-pol QPE [mm/h] (synthetic — see fixtures.md)</Title>
            <Abstract>Synthetic layer: RADAR_1KM_RDPR is not available in the live MSC GeoMet capabilities as of 2026-05-12. Real available layers are RADAR_1KM_RRAI and RADAR_1KM_RSNO. See fixtures.md for details.</Abstract>
            <EX_GeographicBoundingBox>
              <westBoundLongitude>-170.320000</westBoundLongitude>
              <eastBoundLongitude>-50.000000</eastBoundLongitude>
              <southBoundLatitude>16.930000</southBoundLatitude>
              <northBoundLatitude>67.190000</northBoundLatitude>
            </EX_GeographicBoundingBox>
            <Dimension name="time" units="ISO8601" default="2026-05-12T00:54:00Z" nearestValue="0">2026-05-11T21:54:00Z/2026-05-12T00:54:00Z/PT6M</Dimension>
          </Layer>
          <!-- Real layer from live capture: -->
          <Layer queryable="1" opaque="0" cascaded="0">
            <Name>RADAR_1KM_RRAI</Name>
            <Title>Radar precipitation rate for rain [mm/h]</Title>
            <Abstract>This mosaic is calculated over the North American domain with a horizontal spatial resolution of 1 km.</Abstract>
            <EX_GeographicBoundingBox>
              <westBoundLongitude>-170.320000</westBoundLongitude>
              <eastBoundLongitude>-50.000000</eastBoundLongitude>
              <southBoundLatitude>16.930000</southBoundLatitude>
              <northBoundLatitude>67.190000</northBoundLatitude>
            </EX_GeographicBoundingBox>
            <Dimension name="time" units="ISO8601" default="2026-05-12T00:54:00Z" nearestValue="0">2026-05-11T21:54:00Z/2026-05-12T00:54:00Z/PT6M</Dimension>
            <Style>
              <Name>Radar-Rain_14colors</Name>
              <Title>Radar-Rain_14colors</Title>
            </Style>
          </Layer>
          <Layer queryable="1" opaque="0" cascaded="0">
            <Name>RADAR_1KM_RSNO</Name>
            <Title>Radar precipitation rate for snow [cm/h]</Title>
            <Abstract>This mosaic is calculated over the North American domain with a horizontal spatial resolution of 1 km.</Abstract>
            <EX_GeographicBoundingBox>
              <westBoundLongitude>-170.320000</westBoundLongitude>
              <eastBoundLongitude>-50.000000</eastBoundLongitude>
              <southBoundLatitude>16.930000</southBoundLatitude>
              <northBoundLatitude>67.190000</northBoundLatitude>
            </EX_GeographicBoundingBox>
            <Dimension name="time" units="ISO8601" default="2026-05-12T00:54:00Z" nearestValue="0">2026-05-11T21:54:00Z/2026-05-12T00:54:00Z/PT6M</Dimension>
            <Style>
              <Name>Radar-Snow_14colors</Name>
              <Title>Radar-Snow_14colors</Title>
            </Style>
          </Layer>
        </Layer>
      </Layer>
    </Layer>
  </Capability>
</WMS_Capabilities>
